{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/quartiers-airbnb-courbevoie", "destination": "/blog/quartiers-airbnb-courbevoie", "permanent": true },
    { "source": "/revenu-airbnb-courbevoie", "destination": "/blog/revenu-airbnb-courbevoie", "permanent": true },
    { "source": "/reglementation-airbnb-courbevoie", "destination": "/blog/reglementation-airbnb-courbevoie", "permanent": true },
    { "source": "/calendrier-saisonnier-airbnb-courbevoie", "destination": "/blog/calendrier-saisonnier-airbnb-courbevoie", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
